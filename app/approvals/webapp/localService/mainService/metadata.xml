                            <PropertyValue Property="Target" AnnotationPath="@UI.FieldGroup#Main"/>
                        </Record>
                    </Collection>
                </Annotation>
                <Annotation Term="UI.FieldGroup" Qualifier="Main">
                    <Record Type="UI.FieldGroupType">
                        <PropertyValue Property="Data">
