                        <PropertyValue Property="Updatable" Bool="false"/>
                    </Record>
                </Annotation>
            </Annotations>
            <Annotations Target="AccessPortalService.Services/ID">
                <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
            </Annotations>
            <Annotations Target="AccessPortalService.Services/name">
                <Annotation Term="Common.Label" String="Service"/>
                <Annotation Term="Common.FieldControl" EnumMember="Common.FieldControlType/Mandatory"/>
            </Annotations>
            <Annotations Target="AccessPortalService.Employees/ID">
                <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
            </Annotations>
            <Annotations Target="AccessPortalService.Employees/name">
                <Annotation Term="Common.Label" String="Name"/>
                <Annotation Term="Common.FieldControl" EnumMember="Common.FieldControlType/Mandatory"/>
            </Annotations>
            <Annotations Target="AccessPortalService.Employees/email">
                <Annotation Term="Common.Label" String="Email"/>
                <Annotation Term="Common.FieldControl" EnumMember="Common.FieldControlType/Mandatory"/>
            </Annotations>
            <Annotations Target="AccessPortalService.EntityContainer/Managers">
                <Annotation Term="Capabilities.DeleteRestrictions">
                    <Record Type="Capabilities.DeleteRestrictionsType">
                        <PropertyValue Property="Deletable" Bool="false"/>
                    </Record>
                </Annotation>
                <Annotation Term="Capabilities.InsertRestrictions">
                    <Record Type="Capabilities.InsertRestrictionsType">
                        <PropertyValue Property="Insertable" Bool="false"/>
                    </Record>
                </Annotation>
                <Annotation Term="Capabilities.UpdateRestrictions">
                    <Record Type="Capabilities.UpdateRestrictionsType">
                        <PropertyValue Property="Updatable" Bool="false"/>
                    </Record>
                </Annotation>
            </Annotations>
            <Annotations Target="AccessPortalService.Managers/ID">
                <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
            </Annotations>
            <Annotations Target="AccessPortalService.Managers/name">
                <Annotation Term="Common.FieldControl" EnumMember="Common.FieldControlType/Mandatory"/>
            </Annotations>
            <Annotations Target="AccessPortalService.Managers/email">
                <Annotation Term="Common.FieldControl" EnumMember="Common.FieldControlType/Mandatory"/>
            </Annotations>
            <Annotations Target="AccessPortalService.AccessRequests">
                <Annotation Term="UI.HeaderInfo">
                    <Record Type="UI.HeaderInfoType">
                        <PropertyValue Property="TypeName" String="Access Request"/>
                        <PropertyValue Property="TypeNamePlural" String="Access Requests"/>
                        <PropertyValue Property="Title">
                            <Record Type="UI.DataField">
                                <PropertyValue Property="Value" Path="status"/>
                            </Record>
                        </PropertyValue>
                        <PropertyValue Property="Description">
                            <Record Type="UI.DataField">
                                <PropertyValue Property="Value" Path="reason"/>
                            </Record>
                        </PropertyValue>
                    </Record>
                </Annotation>
                <Annotation Term="UI.LineItem">
                    <Collection>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="employee_ID"/>
                            <PropertyValue Property="Label" String="Employee"/>
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="service_ID"/>
                            <PropertyValue Property="Label" String="Service"/>
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="status"/>
                            <PropertyValue Property="Label" String="Status"/>
