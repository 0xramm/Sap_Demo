                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="employee_ID"/>
                                    <PropertyValue Property="Label" String="Employee"/>
                                </Record>
                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="service_ID"/>
                                    <PropertyValue Property="Label" String="Service"/>
                                </Record>
                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="reason"/>
                                    <PropertyValue Property="Label" String="Reason"/>
                                </Record>
                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="status"/>
                                    <PropertyValue Property="Label" String="Status"/>
                                </Record>
                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="decisionNote"/>
                                    <PropertyValue Property="Label" String="Decision Note"/>
                                </Record>
                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="inviteLink"/>
                                    <PropertyValue Property="Label" String="Invite Link"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>
                <Annotation Term="UI.Identification">
                    <Collection>
                        <Record Type="UI.DataFieldForAction">
                            <PropertyValue Property="Action" String="AccessPortalService.approve"/>
                            <PropertyValue Property="Label" String="Approve"/>
                        </Record>
                        <Record Type="UI.DataFieldForAction">
                            <PropertyValue Property="Action" String="AccessPortalService.declineRequest"/>
                            <PropertyValue Property="Label" String="Reject"/>
                        </Record>
                    </Collection>
                </Annotation>
            </Annotations>
            <Annotations Target="AccessPortalService.AccessRequests/ID">
                <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
            </Annotations>
            <Annotations Target="AccessPortalService.AccessRequests/createdAt">
                <Annotation Term="UI.HiddenFilter" Bool="true"/>
                <Annotation Term="UI.ExcludeFromNavigationContext" Bool="true"/>
                <Annotation Term="Core.Immutable" Bool="true"/>
