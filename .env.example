# Copy this file to .env and fill in real values when you're ready.
# Everything works without these (with placeholder invite links / a test inbox),
# so you don't need any of this to try the app locally.

# --- Discord bot (see srv/lib/discord.js for setup steps) ---
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# --- SMTP (leave blank to use a free auto-generated Ethereal test inbox) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=access-portal@example.com
